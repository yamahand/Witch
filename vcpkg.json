{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg/master/scripts/vcpkg.schema.json",
  "name": "witch",
  "version": "0.1.0",
  "builtin-baseline": "cb2981c4e03d421fa03b9bb5044cd1986180e7e4",
  "dependencies": [
    "stb",
    "mimalloc",
    "nlohmann-json"
  ],
  "features": {
    "profiling": {
      "description": "Enable Tracy profiler client",
      "dependencies": [
        "tracy"
      ]
    },
    "debug-ui": {
      "description": "Enable Dear ImGui debug UI (Win32 + DX12 backend)",
      "dependencies": [
        {
          "name": "imgui",
          "features": ["dx12-binding", "win32-binding"]
        }
      ]
    },
    "tests": {
      "description": "Enable Catch2 unit tests",
      "dependencies": [
        "catch2"
      ]
    }
  }
}
